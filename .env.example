# SecureCallOps local development configuration.
# Copy this file to .env and replace every placeholder before running.

OPS_DB_USER=securecallops
OPS_DB_PASS=change-me-locally
OPS_DB_NAME=securecallops
OPS_DB_HOST=127.0.0.1
OPS_DB_PORT=5432
OPS_DB_SSLMODE=
OPS_DB_POOL_MIN=1
OPS_DB_POOL_MAX=10

# Keep this false for local http:// development. Set true in production.
COOKIE_SECURE=false

# Local-only: logs OTP codes to container logs instead of sending email.
# Keep false in production and configure SMTP instead.
DEV_OTP_LOG=true

# Generate with: python scripts/generate_fernet_key.py
FERNET_KEY=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=
SMTP_FROM=noreply@example.com
